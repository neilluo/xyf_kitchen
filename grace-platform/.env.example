# Grace Platform Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# MySQL Database Configuration
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=grace
MYSQL_USERNAME=grace
MYSQL_PASSWORD=your_mysql_password_here

# ============================================
# Security Configuration
# ============================================
# AES-256-GCM encryption key (Base64 encoded, 32 bytes)
# Generate with: openssl rand -base64 32
GRACE_ENCRYPTION_KEY=your_base64_encoded_aes_key_here

# ============================================
# Alibaba Cloud Qwen LLM Configuration
# ============================================
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# YouTube Data API v3 Configuration
# ============================================
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:8080/api/distribution/auth/youtube/callback

# ============================================
# OpenCrawl API Configuration
# ============================================
OPENCRAWL_API_KEY=your_opencrawl_api_key_here
OPENCRAWL_BASE_URL=https://api.opencrawl.io/v1

# ============================================
# Storage Configuration
# ============================================
GRACE_VIDEO_DIR=./storage/videos
GRACE_TEMP_DIR=./storage/temp
GRACE_AVATAR_DIR=./storage/avatars

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=DEBUG
LOG_FILE=./logs/grace-platform.log
