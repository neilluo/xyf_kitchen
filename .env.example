# ============================================
# Grace Platform - 环境变量模板
# 复制为 .env 并填入实际值
# ============================================

# --- Database (MySQL) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=xyfkitchen
MYSQL_USERNAME=grace
MYSQL_PASSWORD=grace

# --- Encryption (必填) ---
# 生成方式: openssl rand -base64 32
GRACE_ENCRYPTION_KEY=

# --- 阿里云通义千问 LLM (必填) ---
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- YouTube API (必填) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8080/api/distribution/auth/youtube/callback

# --- OpenCrawl (必填) ---
OPENCRAWL_API_KEY=
OPENCRAWL_BASE_URL=https://api.opencrawl.io/v1

# --- File Storage ---
GRACE_VIDEO_DIR=./storage/videos
GRACE_TEMP_DIR=./storage/temp
GRACE_AVATAR_DIR=./storage/avatars

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_FILE=./logs/grace-platform.log

# --- Server ---
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8080/api
